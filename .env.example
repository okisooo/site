# Spotify API Credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Optional: API update token for security (generate a random string)
API_UPDATE_TOKEN=your_secure_random_token_here

# Too Lost release sync (server-side scripts and GitHub Actions only)
# Authorize read:releases at https://developer.toolost.com/docs/api
TOOLOST_ACCESS_TOKEN=your_server_side_bearer_token_here

# OAuth bootstrap credentials. Never expose these through NEXT_PUBLIC_* variables.
TOOLOST_CLIENT_ID=your_toolost_client_id_here
TOOLOST_CLIENT_SECRET=your_toolost_client_secret_here
TOOLOST_REDIRECT_URI=https://okiso.net/api/auth/callback
